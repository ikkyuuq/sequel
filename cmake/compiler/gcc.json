{
  "version": 8,
  "configurePresets": [
    {
      "name": "gcc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_CXX_SCAN_FOR_MODULES": false,
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_C_FLAGS": "-Wall -Werror -Wpedantic -Wconversion",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_FLAGS": "-Wall -Werror -Wpedantic -Wconversion"
      }
    }
  ]
}
