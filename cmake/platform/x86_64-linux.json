{
  "version": 8,
  "include": [
    "../compiler/clang.json",
    "../compiler/gcc.json",
    "../config/binaryDir.json",
    "../config/vcpkg.json",
    "../config/debug.json",
    "../config/release.json",
    "../config/ninja.json"
  ],
  "configurePresets": [
    {
      "name": "x86_64-linux-clang-debug",
      "inherits": [
        "binaryDir",
        "clang",
        "vcpkg",
        "debug",
        "ninja"
      ]
    },
    {
      "name": "x86_64-linux-clang-release",
      "inherits": [
        "binaryDir",
        "clang",
        "vcpkg",
        "release",
        "ninja"
      ]
    },
    {
      "name": "x86_64-linux-gcc-debug",
      "inherits": [
        "binaryDir",
        "gcc",
        "vcpkg",
        "debug",
        "ninja"
      ]
    },
    {
      "name": "x86_64-linux-gcc-release",
      "inherits": [
        "binaryDir",
        "gcc",
        "vcpkg",
        "release",
        "ninja"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "x86_64-linux-clang-debug",
      "configurePreset": "x86_64-linux-clang-debug"
    },
    {
      "name": "x86_64-linux-clang-release",
      "configurePreset": "x86_64-linux-clang-release"
    },
    {
      "name": "x86_64-linux-gcc-debug",
      "configurePreset": "x86_64-linux-gcc-debug"
    },
    {
      "name": "x86_64-linux-gcc-release",
      "configurePreset": "x86_64-linux-gcc-release"
    }
  ]
}
